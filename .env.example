# Anthropic Claude API key — used by api/generate.js to generate website HTML
ANTHROPIC_API_KEY=sk-ant-...

# Resend API key — used to send the demo-ready email and lead notification
RESEND_API_KEY=re_...

# Vercel API token — used to programmatically deploy the generated HTML
VERCEL_TOKEN=

# Vercel team / org id (optional, leave blank for personal account)
VERCEL_TEAM_ID=

# Sender address for outgoing emails (must be a Resend-verified sender)
# Resend cannot send from gmail.com; use a verified domain you own.
FROM_EMAIL=DalaTech <hello@dalatech.online>

# Where new-lead notifications go
LEAD_NOTIFY_EMAIL=dalatech.ai@gmail.com

# Telegram Bot API, used to push a notification to ops on every new lead.
# Create a bot via @BotFather and grab the token; chat_id is the destination
# (your personal chat with the bot, or a group/channel the bot is added to).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Stitch API key, reserved for future UI generation integration. Currently
# unused; the Claude prompt handles design decisions on its own.
STITCH_API_KEY=

# Upstash Redis (REST API) — used by lib/leads.js for lead persistence.
# Vercel's serverless filesystem is read-only, so file-based storage
# (data/leads.json) fails with EROFS in production. Upstash is the
# managed Redis store that backs the lead queue, scheduled sends, and
# the runtime business lookup used by the chatbot.
#
# How to get these:
#   1. Create a free database at https://console.upstash.com (Redis).
#   2. Copy "UPSTASH_REDIS_REST_URL" and "UPSTASH_REDIS_REST_TOKEN".
#   3. In Vercel: Project Settings → Environment Variables, add both
#      for Production, Preview, and Development.
#   4. Redeploy.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Namecheap API — used by the Telegram DOMAIN command (api/telegram.js +
# lib/namecheap.js) to check, purchase, and configure custom domains on
# Bilguun's account. Enable API access at
# https://ap.www.namecheap.com/settings/tools/apiaccess/ and whitelist
# NAMECHEAP_CLIENT_IP (the public IP of the machine making the call;
# Vercel's egress IPs change, so the practical setup is to whitelist a
# small VPS IP and route the calls through it, OR set ApiIp at Namecheap
# to a broad range if your account permits it). NAMECHEAP_USERNAME
# defaults to NAMECHEAP_API_USER when blank. Set NAMECHEAP_SANDBOX=1 to
# point at api.sandbox.namecheap.com for testing.
NAMECHEAP_API_KEY=
NAMECHEAP_API_USER=
NAMECHEAP_USERNAME=
NAMECHEAP_CLIENT_IP=
NAMECHEAP_SANDBOX=

# Registrant contact info Namecheap requires on every namecheap.domains.create
# call (ICANN rule). One block, reused for Registrant + Tech + Admin +
# AuxBilling. Bilguun's own contact info works fine here unless a client
# specifically asks to be listed.
NAMECHEAP_REGISTRANT_FIRSTNAME=
NAMECHEAP_REGISTRANT_LASTNAME=
NAMECHEAP_REGISTRANT_ADDRESS1=
NAMECHEAP_REGISTRANT_CITY=
NAMECHEAP_REGISTRANT_STATEPROVINCE=
NAMECHEAP_REGISTRANT_POSTALCODE=
NAMECHEAP_REGISTRANT_COUNTRY=
NAMECHEAP_REGISTRANT_PHONE=
NAMECHEAP_REGISTRANT_EMAILADDRESS=

# How long to wait after a lead is submitted before the demo email is
# sent. Default 0 = send immediately on the next cron tick (which we
# also trigger inline from api/generate.js). Set to 24 to restore the
# original next-day cadence, or any positive number of hours.
DEMO_DELAY_HOURS=0
