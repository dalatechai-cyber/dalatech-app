{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/generate.js": {
      "maxDuration": 30
    },
    "api/telegram.js": {
      "maxDuration": 300
    },
    "api/cron.js": {
      "maxDuration": 300
    },
    "api/chat.js": {
      "maxDuration": 30
    },
    "api/choice.js": {
      "maxDuration": 30
    },
    "api/morning-report.js": {
      "maxDuration": 60
    },
    "api/follow-up.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/morning-report",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/follow-up",
      "schedule": "0 2 * * *"
    }
  ]
}
